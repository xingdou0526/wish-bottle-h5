# 复制为 .env 后填写真实值（docker compose 会自动读取同目录的 .env）
# 注意：数据库密码请用纯字母数字，避免特殊字符在连接串里需要转义

# 你的域名（已解析到这台服务器的公网 IP）
DOMAIN=wishbottle.example.com

# PostgreSQL
POSTGRES_USER=wishbottle
POSTGRES_PASSWORD=ChangeMeToALongRandomString
POSTGRES_DB=wishbottle

# JWT 密钥（务必改成一段长随机字符串）
JWT_SECRET=ChangeMeToAVeryLongRandomSecret

# 腾讯云 API 密钥，用于 DNS-01 方式申请 HTTPS 证书
# 在腾讯云控制台 → 访问管理(CAM) → API密钥管理 生成
TENCENTCLOUD_SECRET_ID=ChangeMeToYourSecretId
TENCENTCLOUD_SECRET_KEY=ChangeMeToYourSecretKey
