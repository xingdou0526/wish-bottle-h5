# Caddy 配置：{$DOMAIN} 来自环境变量
# - 通过 DNS-01 验证向 Let's Encrypt 申请并自动续期 HTTPS 证书
#   （不需要 Let's Encrypt 反向连入服务器，绕开未备案域名的入站拦截）
{$DOMAIN} {
	encode gzip

	# 用腾讯云 API 密钥走 DNS-01 验证申请证书
	tls {
		dns tencentcloud {
			secret_id {env.TENCENTCLOUD_SECRET_ID}
			secret_key {env.TENCENTCLOUD_SECRET_KEY}
		}
	}

	# 所有 /api/* 请求反向代理到 api 容器
	handle /api/* {
		reverse_proxy api:3000
	}

	# 其余请求托管 React 单页应用（找不到的路径回退到 index.html）
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
