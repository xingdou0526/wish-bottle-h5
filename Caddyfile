# Caddy 配置：{$DOMAIN} 来自环境变量
# - 域名解析到本服务器后，Caddy 会自动向 Let's Encrypt 申请并续期 HTTPS 证书
{$DOMAIN} {
	encode gzip

	# 所有 /api/* 请求反向代理到 api 容器
	handle /api/* {
		reverse_proxy api:3000
	}

	# 其余请求托管 React 单页应用（找不到的路径回退到 index.html）
	handle {
		root * /srv
		try_files {path} /index.html
		file_server
	}
}
